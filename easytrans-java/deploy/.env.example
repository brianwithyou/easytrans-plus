# 复制为 .env 后修改（不要提交 .env 到 Git）
# cp .env.example .env

API_PORT=9091

# --- 连接本机已有 MySQL 8 容器（推荐）---
# 情况 A：MySQL 已映射到宿主机 3306（docker run -p 3306:3306 ...）
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306

# 情况 B：API 与 MySQL 在同一 Docker 网络（见 DEPLOY.md）
# MYSQL_HOST=你的mysql容器名
# MYSQL_PORT=3306
# MYSQL_DOCKER_NETWORK=你的docker网络名
# 启动命令: docker compose -f docker-compose.yml -f docker-compose.mysql-network.yml up -d --build

MYSQL_DATABASE=easytrans
MYSQL_USERNAME=root
MYSQL_PASSWORD=change-me-mysql-password

JWT_SECRET=change-me-jwt-secret-at-least-32-characters

DASHSCOPE_API_KEY=
MIMO_API_KEY=
DEEPSEEK_API_KEY=

# Resend 邮件（注册验证码）
# 注意：from 含空格或尖括号时必须用双引号，否则 source .env 会报错
EMAIL_DEV_MODE=false
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM="EasyTrans <noreply@yourdomain.com>"

# Lemon Squeezy 计费（可选，生产环境只改 .env 即可，无需 application-local.yaml）
# BILLING_ENABLED=false → 基础版免费；true → 必须购买基础版后才能翻译
BILLING_ENABLED=false
LEMON_SQUEEZY_WEBHOOK_SECRET=
BILLING_ALLOW_TEST_MODE=true
# 以下仅在 BILLING_ENABLED=true 时填写（来自 Lemon Squeezy 后台）
BILLING_VARIANT_ID=
BILLING_CHECKOUT_URL=
# BILLING_PLAN_NAME=基础版
# BILLING_DAILY_QUOTA=500000
# BILLING_DURATION_DAYS=30
# BILLING_PRODUCT_LABEL=基础版（1个月）

# CentOS 7 / MySQL 连不上时可设为 true（API 使用宿主机网络，MYSQL_HOST 改为 127.0.0.1）
USE_HOST_NETWORK=false

# 日志目录（可选，映射到宿主机便于查看；不设则用 Docker 卷 easytrans-api-logs）
# LOG_HOST_PATH=/var/log/easytrans
