# 复制为 .env 后修改（不要提交 .env 到 Git）
# cp .env.example .env

API_PORT=9091

# --- 连接本机已有 MySQL 8 容器（推荐）---
# 情况 A：MySQL 已映射到宿主机 3306（docker run -p 3306:3306 ...）
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306

# 情况 B：API 与 MySQL 在同一 Docker 网络（见 DEPLOY.md）
# MYSQL_HOST=你的mysql容器名
# MYSQL_PORT=3306
# MYSQL_DOCKER_NETWORK=你的docker网络名
# 启动命令: docker compose -f docker-compose.yml -f docker-compose.mysql-network.yml up -d --build

MYSQL_DATABASE=easytrans
MYSQL_USERNAME=root
MYSQL_PASSWORD=change-me-mysql-password

JWT_SECRET=change-me-jwt-secret-at-least-32-characters

DASHSCOPE_API_KEY=
MIMO_API_KEY=
DEEPSEEK_API_KEY=

APP_CORS_ALLOWED_ORIGINS=*
