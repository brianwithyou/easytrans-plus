# 复制为 .env 后修改（不要提交 .env 到 Git）
# cp .env.example .env

# API 对外端口（仅本机/内网访问时可保持 9091；前面有 Nginx 时可不改）
API_PORT=9091

# MySQL
MYSQL_DATABASE=easytrans
MYSQL_ROOT_PASSWORD=change-me-strong-mysql-password

# JWT 签名密钥（至少 32 位随机字符串）
JWT_SECRET=change-me-jwt-secret-at-least-32-characters

# LLM API Key（至少配置一个，按 application.yaml 顺序兜底）
DASHSCOPE_API_KEY=
MIMO_API_KEY=
DEEPSEEK_API_KEY=

# 生产环境建议改成你的域名；仅 macOS 客户端直连时可先保持 *
APP_CORS_ALLOWED_ORIGINS=*
